# Copy to .env or export manually before running.
# IMPORTANT: use a fresh mining wallet with limited ETH for gas.
HASH256_PRIVATE_KEY=0xyour_private_key_here

# Optional; defaults to Ethereum mainnet public RPC.
HASH256_RPC_URL=https://ethereum.publicnode.com

# Optional EIP-1559 fee settings for fast inclusion.
# Recent successful HASH mine txs observed around priorityFee 3-8 gwei.
HASH256_PRIORITY_FEE_GWEI=8
HASH256_MAX_FEE_GWEI=20
# HASH256_BASE_FEE_MULTIPLIER=2
