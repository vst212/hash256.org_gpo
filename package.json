{
  "name": "hash256-cli",
  "version": "0.1.0",
  "description": "CPU CLI miner for HASH (hash256.org) using the official WASM miner and Ethereum RPC.",
  "type": "module",
  "bin": {
    "hash256-mine": "./src/cli.js"
  },
  "scripts": {
    "mine": "node ./src/cli.js",
    "mine:gpu": "node ./src/cli.js --gpu",
    "status": "node ./src/cli.js --status",
    "benchmark": "node ./src/cli.js --benchmark",
    "benchmark:gpu": "node ./src/cli.js --gpu --benchmark",
    "check": "node --check ./src/cli.js && node --check ./src/worker.js",
    "refresh-miner": "curl -fsSL https://hash256.org/miner/hash_miner.js -o vendor/miner/hash_miner.js && curl -fsSL https://hash256.org/miner/hash_miner_bg.wasm -o vendor/miner/hash_miner_bg.wasm"
  },
  "dependencies": {
    "ethers": "^6.15.0"
  },
  "optionalDependencies": {
    "node-opencl": "^0.4.5"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "devDependencies": {
    "node-opencl": "^0.4.5"
  }
}
